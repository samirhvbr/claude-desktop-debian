{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment_perfil": "PERFIL OPUS-ONLY — Opus 4.8 em tudo. Janela 1M nativa na API Anthropic (incluso no Max, usar LONGE do limite), por isso NAO setamos CLAUDE_CODE_DISABLE_1M_CONTEXT. Effort 'max' vai pelo env CLAUDE_CODE_EFFORT_LEVEL porque o campo effortLevel so aceita low/medium/high/xhigh. Adaptive thinking OFF. Coexiste com o .claude do upstream (agents/hooks/skills/settings.local.json).",
  "model": "opus",
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "opus",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-8",
    "CLAUDE_CODE_EFFORT_LEVEL": "max"
  },
  "permissions": {
    "_comment": "Permissões do projeto - claude-desktop-debian (bash/electron/packaging)",
    "defaultMode": "plan",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(shellcheck:*)",
      "Bash(bats:*)",
      "Bash(codespell:*)",
      "Bash(node:*)",
      "Bash(node -c:*)",
      "Bash(npm run:*)",
      "Bash(npm ci:*)",
      "Bash(npm install:*)",
      "Bash(npx:*)",
      "Bash(nix build:*)",
      "Bash(nix flake check:*)",
      "Bash(./build.sh:*)"
    ],
    "deny": [
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./.env)",
      "Read(./**/auth.json)",
      "Bash(rm -rf:*)",
      "Bash(rm -rf /:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(curl * | sh:*)",
      "Bash(curl * | bash:*)",
      "Bash(wget * | sh:*)"
    ],
    "ask": [
      "Bash(sudo:*)",
      "Bash(dpkg -i:*)",
      "Bash(apt:*)",
      "Bash(apt-get:*)",
      "Bash(npm install --save:*)"
    ]
  }
}
