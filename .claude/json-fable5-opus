{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment_perfil": "PERFIL FABLE-5 + fallback Opus — Claude Fable 5 no model e nos subagentes; cai pra Opus 4.8 se indisponivel. Janela 1M SEMPRE ativa (Fable/Opus 4.8 rodam 1M por padrao). Effort 'max' vai pelo env CLAUDE_CODE_EFFORT_LEVEL (effortLevel do arquivo so aceita low/medium/high/xhigh). Thinking no Fable 5 e SEMPRE adaptativo (CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING nao tem efeito). CREDITOS: Fable 5 incluso no Max ate ~22/jun/2026; depois consome creditos (~$10/$50 por MTok, 2x o Opus). Requer Claude Code v2.1.170+.",
  "model": "fable",
  "fallbackModel": ["opus"],
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "fable",
    "ANTHROPIC_DEFAULT_FABLE_MODEL": "claude-fable-5",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-8",
    "CLAUDE_CODE_EFFORT_LEVEL": "max"
  },
  "permissions": {
    "_comment": "Permissões do projeto - claude-desktop-debian (bash/electron/packaging)",
    "defaultMode": "plan",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(shellcheck:*)",
      "Bash(bats:*)",
      "Bash(codespell:*)",
      "Bash(node:*)",
      "Bash(node -c:*)",
      "Bash(npm run:*)",
      "Bash(npm ci:*)",
      "Bash(npm install:*)",
      "Bash(npx:*)",
      "Bash(nix build:*)",
      "Bash(nix flake check:*)",
      "Bash(./build.sh:*)"
    ],
    "deny": [
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./.env)",
      "Read(./**/auth.json)",
      "Bash(rm -rf:*)",
      "Bash(rm -rf /:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(curl * | sh:*)",
      "Bash(curl * | bash:*)",
      "Bash(wget * | sh:*)"
    ],
    "ask": [
      "Bash(sudo:*)",
      "Bash(dpkg -i:*)",
      "Bash(apt:*)",
      "Bash(apt-get:*)",
      "Bash(npm install --save:*)"
    ]
  }
}
